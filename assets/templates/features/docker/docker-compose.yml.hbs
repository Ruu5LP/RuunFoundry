{{#eq language "laravel"}}
services:
  app:
    build: .
    ports:
      - "8000:80"
    env_file:
      - .env
    volumes:
      - .:/var/www
      - /var/www/vendor
    depends_on:
      - db
    restart: unless-stopped

  db:
    image: mysql:8.4
    environment:
      MYSQL_DATABASE: ${DB_DATABASE:-app}
      MYSQL_ROOT_PASSWORD: ${DB_PASSWORD:-secret}
    ports:
      - "3306:3306"
    volumes:
      - db-data:/var/lib/mysql
    restart: unless-stopped

volumes:
  db-data:
{{/eq}}
{{#eq language "python"}}
services:
  app:
    build: .
    ports:
      - "8000:8000"
    env_file:
      - .env
    volumes:
      - .:/app
    restart: unless-stopped
{{/eq}}
{{#eq language "typescript"}}
services:
  app:
    build: .
    ports:
      - "3000:3000"
    env_file:
      - .env
    volumes:
      - .:/app
      - /app/node_modules
    restart: unless-stopped
{{/eq}}
